  id           String      @id @default(uuid())
  name         String
  email        String      @unique
  password     String
  phone        String?
  designation  String?
  role         Role        @default(EMPLOYEE)
  departmentId String?     
  status       String      @default("ACTIVE") 
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

