datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ----------------------------------------------------
// ENUMS
// ----------------------------------------------------
enum Role {
  ADMIN
  EMPLOYEE
  ASSET_MANAGER
  DEPARTMENT_HEAD
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  DISPOSED
  RETIRED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

// ----------------------------------------------------
// MODELS
// ----------------------------------------------------
model User {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  email           String            @unique
  password        String
  phone           String?
  designation     String?
  role            Role              @default(EMPLOYEE)
  departmentId    String?           @db.Uuid
  status          String            @default("ACTIVE")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relationships from Module 1
  department      Department?       @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  headedDept      Department?       @relation("DepartmentHead")
  notifications   Notification[]
  activityLogs    ActivityLog[]

  // Relationships from Module 2 (Assets)
  allocations     AssetAllocation[] @relation("EmployeeAllocations")
  allocationsMade AssetAllocation[] @relation("ManagerAllocations")
  transfers       TransferRequest[] @relation("EmployeeTransfers")
  approvals       TransferRequest[] @relation("ManagerApprovals")
  historyLogs     AssetHistory[]

  @@index([email])
}

model Department {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  headId      String?  @unique @db.Uuid
  head        User?    @relation("DepartmentHead", fields: [headId], references: [id])
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees   User[]   @relation("DepartmentEmployees")
  assets      Asset[]
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  description  String?
  customFields Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assets       Asset[]
}

model Asset {
  id              String          @id @default(uuid()) @db.Uuid
  assetTag        String          @unique @db.VarChar(100)
  serialNumber    String          @unique @db.VarChar(255)
  name            String          @db.VarChar(255)
  description     String?         @db.Text
  categoryId      String          @db.Uuid
  departmentId    String          @db.Uuid
  purchaseDate    DateTime        @db.Date
  purchaseCost    Decimal         @db.Decimal(15, 2)
  vendor          String          @db.VarChar(150)
  warrantyExpiry  DateTime?       @db.Date
  location        String          @db.VarChar(255)
  condition       String          @db.VarChar(50)
  status          AssetStatus     @default(AVAILABLE)
  qrCode          String?         @db.Text
  image           String?         @db.Text

  deletedAt       DateTime?       @db.Timestamptz
  createdAt       DateTime        @default(now()) @db.Timestamptz
  updatedAt       DateTime        @updatedAt @db.Timestamptz

  category        Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  department      Department        @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  allocations     AssetAllocation[]
  transfers       TransferRequest[]
  history         AssetHistory[]

  @@index([status])
  @@index([departmentId])
  @@index([categoryId])
  @@index([deletedAt])
}

model AssetAllocation {
  id                 String           @id @default(uuid()) @db.Uuid
  assetId            String           @db.Uuid
  employeeId         String           @db.Uuid
  allocatedBy        String           @db.Uuid
  allocatedDate      DateTime         @default(now()) @db.Timestamptz
  expectedReturnDate DateTime         @db.Timestamptz
  actualReturnDate   DateTime?        @db.Timestamptz
  status             AllocationStatus @default(ACTIVE)
  remarks            String?          @db.Text

  createdAt          DateTime         @default(now()) @db.Timestamptz
  updatedAt          DateTime         @updatedAt @db.Timestamptz

  asset              Asset            @relation(fields: [assetId], references: [id], onDelete: Restrict)
  employee           User             @relation("EmployeeAllocations", fields: [employeeId], references: [id], onDelete: Restrict)
  manager            User             @relation("ManagerAllocations", fields: [allocatedBy], references: [id], onDelete: Restrict)

  @@index([assetId])
  @@index([employeeId])
  @@index([status])
}

model TransferRequest {
  id             String         @id @default(uuid()) @db.Uuid
  assetId        String         @db.Uuid
  requestedBy    String         @db.Uuid
  fromDepartment String         @db.Uuid
  toDepartment   String         @db.Uuid
  approvedBy     String?        @db.Uuid
  status         TransferStatus @default(PENDING)
  reason         String         @db.Text

  createdAt      DateTime       @default(now()) @db.Timestamptz
  updatedAt      DateTime       @updatedAt @db.Timestamptz

  asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Restrict)
  requester      User           @relation("EmployeeTransfers", fields: [requestedBy], references: [id], onDelete: Restrict)
  approver       User?          @relation("ManagerApprovals", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([status])
}

model AssetHistory {
  id          String   @id @default(uuid()) @db.Uuid
  assetId     String   @db.Uuid
  action      String   @db.VarChar(100)
  performedBy String   @db.Uuid
  description String   @db.Text
  timestamp   DateTime @default(now()) @db.Timestamptz

  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [performedBy], references: [id], onDelete: Restrict)

  @@index([assetId])
  @@index([timestamp])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  action      String
  module      String
  description String
  createdAt   DateTime @default(now())
}